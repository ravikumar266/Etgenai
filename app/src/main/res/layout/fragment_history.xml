<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/context/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/monolith_bg"
    tools:context=".ui.history.HistoryFragment">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:background="#B30D1117"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_history"
            app:tint="@color/primary" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chat History"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <View
        android:id="@+id/topDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#332F80ED"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- 🔥 IMPROVED EMPTY STATE -->
    <LinearLayout
        android:id="@+id/emptyStateContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_nav_history"
            app:tint="@color/outline"
            android:alpha="0.6"/>

        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No conversation threads yet"
            android:textColor="@color/outline"
            android:textSize="14sp"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

    <!-- 🔥 THREAD LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvThreads"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        android:clipToPadding="false"

        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
